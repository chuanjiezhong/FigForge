{
  "name": "figforge",
  "productName": "FigForge",
  "version": "0.1.0",
  "description": "科研可视化与图件生产平台",
  "main": "out/main/index.js",
  "author": {
    "name": "学术有途",
    "email": "chuanjiezhongloveluosiya@gmail.com"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "node scripts/fix-crypto.js && electron-vite dev",
    "build": "node scripts/run-build.js",
    "build:prod": "NODE_ENV=production electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "clean:release": "node scripts/clean-release.js",
    "clean:release:mac": "node scripts/clean-release.js mac",
    "clean:release:win": "node scripts/clean-release.js win",
    "clean:release:linux": "node scripts/clean-release.js linux",
    "dist:mac": "npm run build && node scripts/clean-release.js mac && electron-builder --mac --config.directories.output=release/mac",
    "dist:win": "npm run build && node scripts/clean-release.js win && electron-builder --win --config.directories.output=release/win",
    "dist:linux": "npm run build && node scripts/clean-release.js linux && electron-builder --linux --config.directories.output=release/linux"
  },
  "dependencies": {
    "antd": "^5.12.0",
    "canvas": "^3.2.1",
    "dagre": "^0.8.5",
    "fabric": "^5.3.0",
    "fs-extra": "^11.2.0",
    "pdf-lib": "^1.17.1",
    "pdf-poppler": "^0.2.1",
    "pdfjs-dist": "^5.4.530",
    "puppeteer": "^21.6.0",
    "reactflow": "^11.11.4",
    "sharp": "^0.33.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/fabric": "^5.3.11",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.1.0",
    "electron-builder": "24.6.4",
    "electron-vite": "^2.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "javascript-obfuscator": "^5.1.0",
    "less": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rollup-plugin-obfuscator": "^1.1.0",
    "terser": "^5.44.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  },
  "build": {
    "appId": "com.figforge.app",
    "productName": "FigForge",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "pipelines/**/*",
      "templates/**/*",
      "package.json",
      "function-docs.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "npmRebuild": false,
    "afterPack": "./scripts/afterPack.js",
    "extraFiles": [
      {
        "from": "pipelines",
        "to": "pipelines",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "templates",
        "to": "templates",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.science",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Science",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
